# Production env for the Next.js supplier portal. Copy to /opt/fastflow/web/.env

# Local Postgres created on the VPS (see DEPLOY.md). Use a strong password.
DATABASE_URL="postgresql://fastflow:CHANGE_ME@localhost:5432/fastflow?schema=public"

# --- Self-hosted auth (better-auth) ---
# Random 32-byte secret that signs session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET="CHANGE_ME_long_random_string"
# Public origin of the portal (no trailing slash). Must match the real domain.
BETTER_AUTH_URL="https://portal.fastflow.global"

# --- SMS for phone + OTP login (mainland-China suppliers) ---
# "console" prints codes to the portal log (lets you launch before SMS is wired).
# Switch to "aliyun"/"tencent" and add the provider creds in src/lib/sms.ts.
SMS_PROVIDER="console"

# Public URL of the buyer site (used by the portal landing's "Back to main site").
NEXT_PUBLIC_MAIN_SITE_URL="https://fastflow.global"

# Emails granted ADMIN platformRole on first sign-up (broker queue + KYB review).
PLATFORM_ADMIN_EMAILS="you@yourcompany.com"
