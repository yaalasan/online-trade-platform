# Production env for the Next.js supplier portal. Copy to /opt/fastflow/web/.env

# Local Postgres created on the VPS (see DEPLOY.md). Use a strong password.
DATABASE_URL="postgresql://fastflow:CHANGE_ME@localhost:5432/fastflow?schema=public"

# --- Clerk PRODUCTION keys (pk_live_… / sk_live_…) ---
# Create a Production instance in the Clerk dashboard for portal.fastflow.global,
# then paste its keys here. (Test pk_test_/sk_test_ keys will NOT work on a real domain.)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_xxx"
CLERK_SECRET_KEY="sk_live_xxx"
# Clerk dashboard -> Webhooks -> endpoint https://portal.fastflow.global/api/webhooks/clerk
CLERK_WEBHOOK_SECRET="whsec_xxx"

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Public URL of the buyer site (used by the portal landing's "Back to main site").
NEXT_PUBLIC_MAIN_SITE_URL="https://fastflow.global"

# Emails granted ADMIN platformRole on first sign-in (broker queue + KYB review).
PLATFORM_ADMIN_EMAILS="you@yourcompany.com"
