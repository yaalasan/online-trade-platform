# Production env for the Flask marketplace. Copy to /opt/fastflow/.env
# systemd reads this as KEY=value lines (no `export`, comments with # are fine).

# REQUIRED in production. Generate once with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Turns on secure cookies + enables the nginx ProxyFix trust.
PRODUCTION=1

# The supplier portal the buyer site reads its live catalog from (same server).
PORTAL_API_URL=http://127.0.0.1:3000
# Public portal URL used for "Supplier Portal" / "List your company" buttons.
PORTAL_URL=https://portal.fastflow.global
# Bridge HTTP timeout (seconds).
PORTAL_TIMEOUT=2.5

# NOTE: do NOT set BIND_ALL — gunicorn binds 127.0.0.1:5000 and nginx proxies it.
