# Fastflow buyer site (Flask) — copy to .env and adjust. No real secrets here.

# Flask session signing key. REQUIRED in production; dev uses an ephemeral key.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Supplier portal (Next.js) the buyer site reads its catalog from.
PORTAL_API_URL=http://localhost:3000
# Portal URL used for the "Supplier Portal" / "List your company" buttons.
PORTAL_URL=http://localhost:3000
# Bridge HTTP timeout in seconds.
PORTAL_TIMEOUT=2.5

# Production toggles (leave unset for local development).
# PRODUCTION=1     # enables secure cookies + requires SECRET_KEY
# FLASK_DEBUG=1    # dev-only debug mode
# BIND_ALL=1       # bind 0.0.0.0 instead of 127.0.0.1
