# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fastflow?schema=public"

# --- Clerk (https://dashboard.clerk.com) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
# Signing secret for the /api/webhooks/clerk endpoint (Clerk dashboard → Webhooks)
CLERK_WEBHOOK_SECRET="whsec_xxx"

# Where Clerk sends users for auth + after auth
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# --- Platform staff (Fastflow brokers) ---
# Comma-separated emails granted ADMIN platformRole on first sign-in. Bootstraps
# the broker queue + KYB approval without manual DB edits.
PLATFORM_ADMIN_EMAILS="ops@fastflow.example"
