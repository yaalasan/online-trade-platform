# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fastflow?schema=public"

# --- Self-hosted auth (better-auth) ---
# Random 32-byte secret that signs session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET="replace-with-a-long-random-string"
# Public origin of the portal (no trailing slash).
# Dev: http://localhost:3000   Prod: https://portal.fastflow.global
BETTER_AUTH_URL="http://localhost:3000"

# --- SMS for phone + OTP login (the path that works in mainland China) ---
# "console"  → print codes to the server log (local dev, no provider needed)
# "aliyun"   → Alibaba Cloud Dysms   (wire creds in src/lib/sms.ts)
# "tencent"  → Tencent Cloud SMS     (wire creds in src/lib/sms.ts)
SMS_PROVIDER="console"

# --- Platform staff (Fastflow brokers) ---
# Comma-separated emails granted ADMIN platformRole on first sign-up. Bootstraps
# the broker queue + KYB approval without manual DB edits.
PLATFORM_ADMIN_EMAILS="ops@fastflow.example"
